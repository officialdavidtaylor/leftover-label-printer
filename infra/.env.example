COMPOSE_PROJECT_NAME=leftover-label-printer
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme
EMQX_DASHBOARD_USERNAME=admin
EMQX_DASHBOARD_PASSWORD=public
EMQX_DEPLOYMENT_ENV=local
EMQX_REQUIRE_TLS=false
EMQX_ENABLE_PLAIN_MQTT=true
EMQX_TLS_CERT_DIR=./emqx/certs
EMQX_TLS_CA_CERT_FILE=ca.crt
EMQX_TLS_CERT_FILE=server.crt
EMQX_TLS_KEY_FILE=server.key
EMQX_BACKEND_MQTT_USERNAME=backend
EMQX_BACKEND_MQTT_PASSWORD=change-me-backend
EMQX_AGENT_MQTT_USERNAME=printer-01
EMQX_AGENT_MQTT_PASSWORD=change-me-agent
EMQX_API_URL=http://localhost:18083/api/v5
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
DEV_KEYCLOAK_BASE_URL=http://localhost:9000
DEV_KEYCLOAK_BOOTSTRAP_BASE_URL=http://127.0.0.1:9000
DEV_OIDC_REALM=leftover-label-printer
DEV_OIDC_AUDIENCE=leftover-label-printer-api
DEV_OIDC_DEV_CLIENT_ID=leftover-label-printer-dev-cli
DEV_OIDC_PWA_CLIENT_ID=leftover-label-printer-pwa
DEV_OIDC_DEV_USERNAME=dev-user
DEV_OIDC_DEV_PASSWORD=dev-password
DEV_OIDC_DEV_ROLES=user
DEV_BACKEND_BASE_URL=http://localhost:8080
DEV_FRONTEND_PORT=3000
DEV_FRONTEND_BASE_URL=http://localhost:3000
DEV_PRINTER_ID=printer-01
DEV_PRINTER_LOCATION=Local Dev Bench
DEV_TEMPLATE_ID=label-default
DEV_TEMPLATE_VERSION=v1
DEV_MINIO_BASE_URL=http://localhost:9002
DEV_S3_BUCKET=leftover-label-printer
DEV_S3_REGION=us-east-1
DEV_MOCK_PRINT_FAIL_MARKER=[mock-fail]
